{
    "name": "Solar-World Django",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspaces/Solar-World",
    "postCreateCommand": "pip install --user -r requirements.txt && python manage.py migrate",
    "postAttachCommand": {
        "server": "python manage.py runserver 0.0.0.0:8000"
    },
    "containerEnv": {
        "SECRET_KEY": "django-insecure-8&*^#@!$%^&*()_+~`1234567890"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    "forwardPorts": [ 8000 ],
    "portsAttributes": {
        "8000": {
            "label": "Django Server",
            "onAutoForward": "notify"
        }
    }
}